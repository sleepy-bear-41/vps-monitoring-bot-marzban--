[Unit]
Description=Node Monitor Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/vps-node
ExecStart=/usr/bin/python3 /opt/vps-node/node_monitor.py
Restart=always
RestartSec=10
StandardOutput=append:/opt/vps-node/node_monitor.log
StandardError=append:/opt/vps-node/node_monitor.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
