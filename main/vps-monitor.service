[Unit]
Description=Main VPS Monitor Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/vps-monitor
ExecStart=/usr/bin/python3 /opt/vps-monitor/monitor.py
Restart=always
RestartSec=10
StandardOutput=append:/opt/vps-monitor/monitor.log
StandardError=append:/opt/vps-monitor/monitor.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
